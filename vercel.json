{
  "version": 2,
  "builds": [
    {
      "src": "api/trpc/[trpc].ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "buildCommand": "pnpm install && pnpm build",
        "outputDirectory": "dist/public"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/trpc/(.*)",
      "dest": "/api/trpc/[trpc].ts"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
